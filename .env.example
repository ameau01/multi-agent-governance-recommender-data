# ============================================================
# .env.example — copy this to .env and fill in real values.
# .env is gitignored; .env.example is checked in as a template.
# ============================================================

# ----------------------------------------------------------
# Anthropic API (REQUIRED for Pass 1, Pass 2, and smoke test)
# ----------------------------------------------------------
# Get a key at https://console.anthropic.com
# (separate account from claude.ai — has its own billing setup)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ----------------------------------------------------------
# LangSmith tracing (RECOMMENDED but optional)
# ----------------------------------------------------------
# Get an account + key at https://smith.langchain.com
# When LANGSMITH_TRACING=true, every Anthropic SDK call is automatically
# logged to the LangSmith project named below.
# If LANGSMITH_TRACING is unset or "false", tracing is a no-op — the pipeline
# runs exactly as if LangSmith were not installed.

LANGSMITH_TRACING=true
LANGSMITH_API_KEY=ls_your-key-here
LANGSMITH_PROJECT=multi-agent-governance-recommender-data
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
