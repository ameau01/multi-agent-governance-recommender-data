# ============================================================
# .env.example — copy this to .env and fill in real values.
# .env is gitignored; .env.example is checked in as a template.
# ============================================================
#
# After editing your .env, verify it without exposing values:
#     bash bin/check_env.sh
#
# After changing any DATAGEN_* tunable below, view the loaded config:
#     uv run python -m generator.cli config
# ============================================================


# ============================================================
# REQUIRED: Anthropic API key
# ============================================================
# Get a key at https://console.anthropic.com
# Real keys are ~108 characters and start with "sk-ant-api03-".
# A short key (< 50 chars) is almost certainly a placeholder.
ANTHROPIC_API_KEY=sk-ant-api03-your-real-key-goes-here-this-is-just-a-placeholder


# ============================================================
# OPTIONAL: LangSmith tracing
# ============================================================
# When LANGSMITH_TRACING=true, every Anthropic SDK call is logged to the
# LangSmith project named below. Set to false or unset to disable tracing
# entirely (no overhead, no behavioral change).
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_your-key-here
LANGSMITH_PROJECT=multi-agent-governance-recommender-data
LANGSMITH_ENDPOINT=https://api.smith.langchain.com


# ============================================================
# OPTIONAL: Operational parameters (all have sensible defaults)
# ============================================================
# Override any of these to tune behavior without code changes.
# Defaults shown match the values logged in CHANGELOG as the chosen design.

# Model assignments
# Defaults: Sonnet for Pass 1 + Pass 2, Opus for smoke test, Haiku for judge
# DATAGEN_PASS1_MODEL=claude-sonnet-4-6
# DATAGEN_PASS2_MODEL=claude-sonnet-4-6
# DATAGEN_SMOKE_TEST_MODEL=claude-opus-4-6
# DATAGEN_SMOKE_TEST_JUDGE_MODEL=claude-haiku-4-5-20251001

# LLM call parameters
# DATAGEN_LLM_TEMPERATURE=0.3

# Retry behavior — applies to Pass 1 and Pass 2 LLM calls.
# Only retries on content failures (JSON parse, schema validation).
# Auth/network errors propagate immediately. Default: 3 attempts.
# DATAGEN_MAX_RETRIES=3

# Max output tokens per LLM call
# DATAGEN_PASS1_MAX_TOKENS=64000
# DATAGEN_PASS2_MAX_TOKENS=64000
# DATAGEN_SMOKE_TEST_MAX_TOKENS=4096
# DATAGEN_JUDGE_MAX_TOKENS=50

# Batch API toggle (50% pricing, async, ~5-30 min completion).
# Recommended for the full 18-scenario run.
# DATAGEN_BATCH_MODE=true
